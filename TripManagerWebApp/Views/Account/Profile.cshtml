@model TripManagerWebApp.Models.ViewModels.UserDetailsVM
@{
    ViewData["Title"] = "Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
</head>
<body>
    <div class="container">
        <div class="profile-card">
            <div class="header">
                <div class="profile-icon">👤</div>
                <h1>Moj Profil</h1>
                <p>Pregledajte i uredite svoje osobne podatke</p>
            </div>

            <div class="profile-container">
                <form action="SaveProfileChanges" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert-danger"></div>

                    <input asp-for="Id" type="hidden" />

                    <div class="info-section">
                        <h3>Osnovne Informacije</h3>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Username" class="form-label"></label>
                                <input asp-for="Username" class="form-input" />
                                <span asp-validation-for="Username" class="validation-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-input" />
                                <span asp-validation-for="Email" class="validation-error"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="FirstName" class="form-label"></label>
                                <input asp-for="FirstName" class="form-input" placeholder="Ime" />
                                <span asp-validation-for="FirstName" class="validation-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="LastName" class="form-label"></label>
                                <input asp-for="LastName" class="form-input" placeholder="Prezime" />
                                <span asp-validation-for="LastName" class="validation-error"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-input" placeholder="Broj telefona" />
                            <span asp-validation-for="PhoneNumber" class="validation-error"></span>
                        </div>
                    </div>

                    <div class="info-section">
                        <h3>Detalji Računa</h3>

                        <div class="detail-row">
                            <span class="detail-label">@Html.DisplayNameFor(model => model.Role)</span>
                            <span class="detail-value role-badge">@Html.DisplayFor(model => model.Role)</span>
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <span class="detail-value">@Html.DisplayFor(model => model.CreatedAt)</span>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" id="saveProfile" class="btn-submit">Spremi promjene</button>
                        <a asp-action="Index" asp-controller="Home" class="btn-back">Povratak</a>
                    </div>
                </form>
                <div id="profilePopup" class="profile-popup" style="display:none;">
                    <span id="profilePopupMsg"></span>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/editProfile.js" asp-append-version="true"></script>
</body>
</html>