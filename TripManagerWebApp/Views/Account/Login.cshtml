@model TripManagerWebApp.Models.ViewModels.UserLoginVM
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="container">
        <div class="form-card">
            <div class="header">
                <h1>Login</h1>
                <p>Welcome back to TripManager</p>
            </div>

            <div class="form-container">
                <form asp-action="Login">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="alert-danger"></div>

                    <div class="form-group">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-input" placeholder="Enter username" />
                        <span asp-validation-for="Username" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-input" placeholder="Enter password" type="password" />
                        <span asp-validation-for="Password" class="validation-error"></span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Login</button>
                    </div>

                    <div class="form-footer">
                        <p>Don't have an account? <a asp-action="Register" class="link-register">Register</a></p>
                        <a asp-action="Index" asp-controller="Home" class="link-back">Back to home</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
