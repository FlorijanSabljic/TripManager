@model TripManagerWebApp.Models.ViewModels.TripVM

@{
    ViewData["Title"] = "Edit";
    Layout = null;
}

<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/editTrip.css" asp-append-version="true" />
</head>
<body>
    <div class="container">
        <div class="form-card">
            <div class="header">
                <h1>Edit Trip</h1>
                <p>Update trip information</p>
            </div>

            <div class="form-container">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert-danger"></div>

                    <input asp-for="Id" type="hidden" />

                    <div class="form-group">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-input" placeholder="Trip name" />
                        <span asp-validation-for="Name" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-textarea" rows="4" placeholder="Trip description"></textarea>
                        <span asp-validation-for="Description" class="validation-error"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" class="form-input" placeholder="Price" />
                            <span asp-validation-for="Price" class="validation-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="MaxParticipants" class="form-label"></label>
                            <input asp-for="MaxParticipants" class="form-input" placeholder="Max. participants" />
                            <span asp-validation-for="MaxParticipants" class="validation-error"></span>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-submit">Save changes</button>
                        <a asp-action="AllTrips" class="btn-back">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
